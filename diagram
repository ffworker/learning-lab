flowchart TB
    User[User / kubectl] --> APIServer[kube-apiserver]

    APIServer --> Etcd[(etcd)]
    APIServer --> Controller[kube-controller-manager]
    APIServer --> Scheduler[kube-scheduler]

    Controller --> Deployment
    Deployment --> ReplicaSet
    ReplicaSet --> PodA[Pod]
    ReplicaSet --> PodB[Pod]

    Scheduler --> PodA
    Scheduler --> PodB

    Service --> PodA
    Service --> PodB
    Ingress --> Service

    subgraph WorkerNode1[Worker Node]
        Kubelet[kubelet]
        Runtime[container runtime]
        PodA
        PodB
    end

    Kubelet <--> APIServer
    PodA --> Runtime
    PodB --> Runtime
